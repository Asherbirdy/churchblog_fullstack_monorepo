{
  "name": "lineoa-monorepo",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "pnpm": ">=9.7.1",
    "node": ">=18.17.0"
  },
  "scripts": {
    "new": "plop package",
    "start": "node run-project.js",
    "clean": "rimraf packages/*/node_modules && rimraf packages/*/dist",
    "clean:all": "rimraf packages/*/node_modules && rimraf packages/*/dist && rimraf node_modules",
    "dev:vite-demo": "pnpm run -C packages/vite-demo dev",
    "build:vite-demo": "pnpm run -C packages/vite-demo build"
  },
  "dependencies": {
    "@line/liff": "2.24.0",
    "@vueuse/core": "^11.1.0",
    "axios": "1.7.7",
    "js-cookie": "3.0.5",
    "naive-ui": "2.38.0",
    "typescript": "5.3.3",
    "unocss": "0.62.3",
    "vite": "5.0.10",
    "vite-plugin-pages": "0.32.3",
    "vite-plugin-vue-layouts": "0.11.0",
    "vue": "3.4.0",
    "vue-router": "4.4.3",
    "vue3-signature": "0.2.4"
  },
  "devDependencies": {
    "@monorepo/libs": "workspace:*",
    "@types/js-cookie": "3.0.6",
    "@types/node": "22.4.2",
    "@typescript-eslint/eslint-plugin": "6.12.0",
    "@typescript-eslint/parser": "6.12.0",
    "@unocss/preset-attributify": "0.62.3",
    "@unocss/preset-uno": "0.62.3",
    "@vitejs/plugin-vue": "5.0.4",
    "@vue/eslint-config-typescript": "13.0.0",
    "eslint": "8.57.0",
    "eslint-plugin-vue": "9.28.0",
    "plop": "3.1.2",
    "rimraf": "6.0.1",
    "unplugin-auto-import": "0.18.2",
    "unplugin-vue-components": "0.27.4",
    "vue-tsc": "1.8.27"
  },
  "workspaces": [
    "packages/*"
  ]
}