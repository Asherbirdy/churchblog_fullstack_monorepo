generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role           String    @default("user")
  access    String[] 
  otp            String?
  otpCreatedTime DateTime?
  otpAttempts    Int       @default(0)
  isBlocked      Boolean   @default(false)
  blockUntil     DateTime?
  tokens         Token[]
  pages     Page[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id           String   @id @default(uuid())
  name         String   @default("")
  routeName    String   @default("")
  status       String   @default("offline")
  setStatus String   @default("none") // scheduledOnline, scheduledOffline, none
  editedHtml   String   @default("") // 編輯中的內容
  onlineHtml   String   @default("") // 上線的內容
  previousHtml String   @default("") // 上次上線的內容
  isEdit       Boolean  @default(false)
  lastEditedAt DateTime @default(now())
  createdBy    User     @relation(fields: [createdById], references: [id])
  createdById  String
  createdAt    DateTime @default(now())
}

model Token {
  id           String   @id @default(uuid())
  refreshToken String
  ip           String
  userAgent    String
  isValid      Boolean  @default(true)
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model ChatTopic {
  id           String     @id @default(uuid())
  name         String
  keywords     String[]
  cards        ChatCard[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ChatCard {
  id           String     @id @default(uuid())
  name         String
  url          String
  chatTopic    ChatTopic  @relation(fields: [chatTopicId], references: [id])
  chatTopicId  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}